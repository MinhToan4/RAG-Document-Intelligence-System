NODE_ENV=development
PORT=4000

DATABASE_URL=
DB_SSL_ENABLED=false
DB_SSL_REJECT_UNAUTHORIZED=true

AI_PROVIDER=gemini
GEMINI_API_KEY=
GROQ_API_KEY=

EMBEDDING_MODEL=gemini-embedding-001
LLM_MODEL=gemini-2.5-flash
LLM_FALLBACK_MODELS=gemini-2.5-flash-lite,gemini-2.0-flash,gemini-2.5-pro,gemini-1.5-pro
LLM_FALLBACK_PROVIDERS=groq
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODELS=llama-3.1-8b-instant
EMBEDDING_DIM=768
JWT_SIGN_KEY=replace_with_a_long_random_secret_key_at_least_32_chars
JWT_ISSUER=RAGDocumentIntelligenceSystem
JWT_ACCESS_TOKEN_DURATION=3600
JWT_REFRESH_TOKEN_DURATION=604800

CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_DEFAULT=5
MAX_FILE_SIZE_MB=20

FRONTEND_ORIGIN=
