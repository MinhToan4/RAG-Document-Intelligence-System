{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": [
      "node",
      "express",
      "multer"
    ],
    "baseUrl": "./src",
    "noEmit": true
  },
  "include": [
    "src",
    "scripts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
